TZ=Europe/Berlin
HOST=0.0.0.0
PORT=8080
UPLOAD_DIR=/uploads
META_DIR=/data/meta
AUTH_DB_PATH=/data/auth/better-auth.sqlite
MAX_FILE_SIZE_MB=500
ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain
MAX_PARALLEL_UPLOADS=3
RATE_LIMIT_PER_MIN=30
CADDY_DOMAIN=drop.iuk-ue.de
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_BASE_URL=https://drop.iuk-ue.de
POCKET_ID_DISCOVERY_URL=https://pocketid.example/.well-known/openid-configuration
POCKET_ID_CLIENT_ID=dropzone
POCKET_ID_CLIENT_SECRET=replace_with_pocketid_client_secret

# Container user/group for host bind mount write permissions
DROP_UID=1000
DROP_GID=1000
